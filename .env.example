# Copy to .env (local) or set these in your host's env (Vercel/Railway).
# .env is gitignored — never commit real secrets.

# --- Database ---
# Local dev: a local SQLite file.
DATABASE_URL="file:./dev.db"
# Production (Turso / libSQL): set these and they take precedence over DATABASE_URL.
# Get them from `turso db show <name>` and `turso db tokens create <name>`.
TURSO_DATABASE_URL=""
TURSO_AUTH_TOKEN=""

# --- Auth ---
# REQUIRED in production: 32+ char random secret (the app refuses to boot without it).
# Generate: openssl rand -base64 48
AUTH_SECRET="dev-only-change-me-please-32chars-min-secret-0001"
SESSION_TTL_SECONDS="604800"

# --- App ---
# Public base URL — used to build email verification links. Set to your real domain in prod.
APP_URL="http://localhost:3000"
APP_NAME="Film Room 影片室"

# --- Email ---
# "console" (dev: prints + writes to .mail/) or "smtp" (production).
EMAIL_PROVIDER="console"
EMAIL_FROM="Film Room <no-reply@filmroom.local>"
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""

# --- Seed (super admin created by prisma/seed.ts) ---
SEED_SUPERADMIN_USERNAME="superadmin"
SEED_SUPERADMIN_EMAIL="you@example.com"
SEED_SUPERADMIN_PASSWORD="change-me-strong-password"
